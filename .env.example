# ─────────────────────────────────────────────────────────────
# Kontaktní formulář – doručování přes SMTP schránku
# (např. office@fscs.cz u poskytovatele domény).
# Zkopíruj tento soubor do .env.local a doplň reálné hodnoty.
# .env.local je v .gitignore a NIKDY se necommituje.
# ─────────────────────────────────────────────────────────────

# SMTP server poskytovatele domény (najdeš v nastavení e-mailu / poště).
# Příklady: smtp.forpsi.com, smtp.wedos.net, smtp.active24.com …
SMTP_HOST=

# Port: 465 (implicitní TLS, doporučeno) nebo 587 (STARTTLS).
SMTP_PORT=465

# Přihlašovací údaje ke schránce (obvykle celá e-mailová adresa a její heslo).
SMTP_USER=office@fscs.cz
SMTP_PASS=

# Volitelné: vynutit režim TLS. Když nevyplníš, odvodí se z portu
# (465 → true, jinak false).
# SMTP_SECURE=true

# Odesílatel. Musí odpovídat schránce v SMTP_USER, jinak server odmítne.
CONTACT_FROM="Web fscs.cz <office@fscs.cz>"

# Kam se poptávky z formuláře doručují.
CONTACT_TO=office@fscs.cz
