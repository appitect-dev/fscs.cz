# ─────────────────────────────────────────────────────────────
# Kontaktní formulář – doručování přes Resend (pouze server-side)
# Zkopíruj tento soubor do .env.local a doplň reálné hodnoty.
# .env.local je v .gitignore a NIKDY se necommituje.
# ─────────────────────────────────────────────────────────────

# API klíč z https://resend.com/api-keys (začíná "re_").
# Používá se jen v route handleru na serveru – neprefixovat NEXT_PUBLIC.
RESEND_API_KEY=

# Odesílatel. Musí být na doméně ověřené v Resend (https://resend.com/domains).
# Pro rychlý test bez ověřené domény lze použít "onboarding@resend.dev"
# (v testovacím režimu Resend doručí jen na e-mail vlastníka účtu).
CONTACT_FROM="Web fscs.cz <formular@fscs.cz>"

# Kam se poptávky z formuláře doručují.
CONTACT_TO=office@fscs.cz
